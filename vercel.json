{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "api/**/*.php", "use": "vercel-php@0.9.0" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)\\.php", "dest": "/$1.php" },
    { "src": "/((?!assets|data|api|.*\\.).*)", "dest": "/$1.php" }
  ]
}
