{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "api/**/*.php", "use": "vercel-php@0.9.0" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*)\\.php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/$1.php" }
  ]
}
