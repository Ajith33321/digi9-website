{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.7.0" },
    { "src": "api/**/*.php", "use": "vercel-php@0.7.0" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*).html", "dest": "/$1.html" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
